 2017MY | Trailer Assist System | Instrument Cluster</span></a><a class="modelimgviewimg" title="Volkswagen Tiguan | 2017MY | Trailer Assist System | Instrument Cluster" href="https://www.caricos.com/cars/v/vw/2017_volkswagen_tiguan/images/92.html"><img class="galprev" alt="Volkswagen Tiguan | 2017MY | Trailer Assist System | Instrument Cluster" data-src="https://images.caricos.com/v/vw/2017_volkswagen_tiguan/images/gallery_8.jpg?1473353108"></a></div><div class="modelimgviewmj" itemprop="image" itemscope itemtype="https://schema.org/ImageObject"><a itemprop="contentUrl" class="modelimgviewimg" href="https://images.caricos.com/v/vw/2017_volkswagen_tiguan/images/2560x1440/2017_volkswagen_tiguan_93_2560x1440.jpg" style="font-size:0.7rem;"><span itemprop="caption">Volkswagen Tiguan | 2017MY | Trailer Assist System | Instrument Cluster</span></a><a class="modelimgviewimg" title="Volkswagen Tiguan | 2017MY | Trailer Assist System | Instrument Cluster" href="https://www.caricos.com/cars/v/vw/2017_volkswagen_tiguan/images/93.html"><img class="galprev" alt="Volkswagen Tiguan | 2017MY | Trailer Assist System | Instrument Cluster" data-src="https://images.caricos.com/v/vw/2017_volkswagen_tiguan/images/gallery_8.jpg?1473353108"></a></div></div></div></div>			<script>
				$(document).ready(function () {
					function loadgal(){
						var p;
						var pprev;
						var pnext;
						var divcont = "";
						if(window.location.hash) {
							p = window.location.hash.substring(1);
							if((p < 1) || (p > 8) || (p == 'mc')){
								p = 1;
							}
						}
						else{
							p = 1;
						}
						
						$('.bgc5').attr("class", "p1");
						$('#pgn'+p).attr("class", "bgc5");

						if(p > 1){
							pprev = Number(p) - Number(1);
							$('#pgnprev').attr("href", "https://www.caricos.com/cars/v/vw/2017_volkswagen_tiguan/#"+pprev);
							$('#pgnprev').attr("class", "prevnext prev pna");
						}
						else if(p == 'videos'){
							pprev = 8;
							$('#pgnprev').attr("href", "https://www.caricos.com/cars/v/vw/2017_volkswagen_tiguan/#"+pprev);
							$('#pgnprev').attr("class", "prevnext prev pna");
						}
						else{
							$('#pgnprev').attr("href", "https://www.caricos.com/cars/v/vw/2017_volkswagen_tiguan/#"+p);
							$('#pgnprev').attr("class", "prevnext prev off");
						}
						
						if(p < 8){
							pnext = Number(p) + Number(1);
							$('#pgnnext').attr("href", "https://www.caricos.com/cars/v/vw/2017_volkswagen_tiguan/#"+pnext);
							$('#pgnnext').attr("class", "prevnext next pna");
						}
						else if(p == 8){
							if(false){
								pnext = "videos";
								$('#pgnnext').attr("href", "https://www.caricos.com/cars/v/vw/2017_volkswagen_tiguan/#"+pnext);
								$('#pgnnext').attr("class", "prevnext next pna");
							}
							else{
								$('#pgnnext').attr("href", "https://www.caricos.com/cars/v/vw/2017_volkswagen_tiguan/#"+p);
								$('#pgnnext').attr("class", "prevnext next off");
							}
						}
						else{
							if(p == 'videos'){
								$('#pgnnext').attr("href", "https://www.caricos.com/cars/v/vw/2017_volkswagen_tiguan/#"+p);
								$('#pgnnext').attr("class", "prevnext next off");
							}
						}
						
						if(p == 'videos'){
							var poffset = 8*100;
							$('#galmj').css("left", "-" + poffset + "%");
						}
						else{
							var poffset = (p-1)*100;
							$('#galmj').css("left", "-" + poffset + "%");
						}
						
						$("#galpage" + p + ", #galpage" + pprev + ", #galpage" + pnext).find("img").each(function(){
							var src = $(this).attr("data-src");
							$(this).attr("src", src);
							$(this).css("display", "block");
						
						});	

						$('#page-select').val(p);

						$('#page-select').on('change', function(){
							window.location.hash = $(this).val();
						});
					}

					// function hideimages(){
					// 	$("#galmj").find("img").each(function(){
					// 		var src = $(this).attr("src");
					// 		$(this).attr("data-src", src);
					// 		$(this).removeAttr("src");
					// 		$(this).css("display", "none");
						
					// 	});	
					// }

					// hideimages();
					loadgal();

					//window.onhashchange = loadgal;
					window.onhashchange = function () {
						if(window.location.hash) {
							p = window.location.hash.substring(1);
							if((p < 1) || (p > 8) || (p == 'mc')){
								p = 1;
							}
							else{
								// ga('set', 'page', '/cars/v/vw/2017_volkswagen_tiguan/#'+p);
								// ga('send', 'pageview');
